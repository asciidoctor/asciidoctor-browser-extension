{
  "name": "asciidoctor-browser-extension",
  "type": "module",
  "description": "Render AsciiDoc (.ad, .adoc, .asc, .asciidoc) as HTML inside your browser!",
  "version": "3.0.1",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "test": "playwright test",
    "build:highlightjs": "node tasks/update-highlight-languages.js",
    "build": "npm run lint && node tasks/build.js",
    "lint": "biome check",
    "format": "biome format --write",
    "validate:firefox": "addons-linter dist/asciidoctor-browser-extension-firefox-*.zip"
  },
  "homepage": "https://github.com/asciidoctor/asciidoctor-browser-extension",
  "author": {
    "name": "Guillaume Grossetie"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:asciidoctor/asciidoctor-browser-extension.git"
  },
  "bugs": {
    "url": "https://github.com/asciidoctor/asciidoctor-browser-extension/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "@asciidoctor/core": "2.2.6",
    "@biomejs/biome": "^2.4.13",
    "@playwright/test": "^1.59.1",
    "addons-linter": "10.3.0",
    "archiver": "5.3.1",
    "asciidoctor-kroki": "0.17.0",
    "bulma": "0.9.4",
    "chartist": "0.11.4",
    "csso": "5.0.5",
    "font-awesome": "4.7.0",
    "mathjax": "3.2.2",
    "sass": "1.63.3",
    "sinon": "15.1.0"
  },
  "keywords": [
    "browser",
    "chrome",
    "chromium",
    "opera",
    "firefox",
    "extension",
    "asciidoctor"
  ],
  "volta": {
    "node": "24.14.1"
  }
}
